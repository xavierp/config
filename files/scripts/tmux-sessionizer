#!/usr/bin/env bash
# tmux-sessionizer: fuzzy-find existing sessions or project dirs, then switch/create

SEARCH_DIRS=(
  ~/src
)

active_sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null)
current_session=$(tmux display-message -p "#{session_name}" 2>/dev/null)

project_dirs=$(find "${SEARCH_DIRS[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)

# Build list: active sessions first (marked), then project dirs without an existing session
{
  for s in $active_sessions; do
    echo "[session] $s"
  done
  for dir in $project_dirs; do
    name=$(basename "$dir" | tr './ ' '---')
    if ! echo "$active_sessions" | grep -qx "$name"; then
      echo "$dir"
    fi
  done
} | grep -v "^\[session\] ${current_session}$" \
  | fzf --reverse --prompt="switch > " --header="active sessions / new projects" \
  | read -r selected

if [[ -z "$selected" ]]; then
  exit 0
fi

if [[ "$selected" == \[session\]* ]]; then
  session_name="${selected#\[session\] }"
  tmux switch-client -t "$session_name"
else
  session_name=$(basename "$selected" | tr './ ' '---')
  if tmux has-session -t="$session_name" 2>/dev/null; then
    tmux switch-client -t "$session_name"
  else
    tmux new-session -d -s "$session_name" -c "$selected"
    tmux switch-client -t "$session_name"
  fi
fi
